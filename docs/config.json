{
  "default_style": "journalist",
  "styles": {
    "journalist": {
      "label": "📰 記者風",
      "description": "新聞記者が書く簡潔・客観的な文体。事実と数値を中心に。",
      "prompt_instruction": "新聞記者として、簡潔・客観的に事実と数値を中心に記述してください。語末は「〜した」「〜となった」など断定調で。各ハイライトは150字以内。"
    },
    "friendly": {
      "label": "😊 フレンドリー",
      "description": "信頼できる知人が話しかけるような親しみやすい文体。",
      "prompt_instruction": "信頼できる知人が読者に話しかけるような文体で書いてください。「〜ですね」「〜みたいですよ」など親しみのある語尾で。各ハイライトは150字以内。"
    },
    "brief": {
      "label": "📋 箇条書き",
      "description": "要点のみ箇条書き。10行以内で全体を把握できる時短スタイル。",
      "prompt_instruction": "箇条書きのみで記述してください。テーマごとに3点以内、全体10行以内。装飾的な表現は不要。"
    },
    "analytical": {
      "label": "🔍 分析",
      "description": "データ・背景・影響を重視する深い分析文体。",
      "prompt_instruction": "データと根拠を重視し、背景・因果関係・今後の影響まで踏み込んで記述してください。各ハイライトは200字以内。"
    }
  },

{
  "name": "news-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "validate": "tsx src/cli.ts validate",
    "validate:existing": "tsx src/cli.ts validate-existing",
    "migrate:dry": "tsx src/cli.ts migrate --dry-run",
    "migrate": "tsx src/cli.ts migrate",
    "ingest": "tsx src/cli.ts ingest",
    "export": "tsx src/cli.ts export",
    "mark-run": "tsx src/cli.ts mark-run",
    "publish:backfill": "tsx src/cli.ts publish:backfill",
    "publish:backfill:dry": "tsx src/cli.ts publish:backfill --dry-run",
    "verify:public": "tsx src/cli.ts verify:public",
    "sync:supplemental": "tsx src/cli.ts sync:supplemental",
    "test:rules": "firebase emulators:exec --only firestore --project demo-news-dashboard \"npm test\""
  },
  "dependencies": {
    "firebase-admin": "^14.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.0.0",
    "firebase": "^12.16.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
